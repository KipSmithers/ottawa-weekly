---
const year = new Date().getFullYear();
---

<footer class="bg-forest border-t border-forest-mid">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <!-- Brand -->
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2 mb-3 group">
          <span class="text-gold group-hover:text-gold-light transition-colors duration-200 w-5 h-5">
            <svg viewBox="0 0 100 112" fill="currentColor" aria-hidden="true" class="w-full h-full">
              <path d="M50 4 C50 4 47.5 18 46 21 C44.5 24 36 17 36 17 C36 17 39 27 37 31 C35 35 24 31 24 31 C24 31 30 40 28 44 C26 48 14 46 14 46 C14 46 21 54 21 58 C21 62 8 62 8 62 C8 62 22 68 24 72 C26 76 18 88 18 88 C18 88 32 83 40 86 L40 96 L44 108 L56 108 L60 96 L60 86 C68 83 82 88 82 88 C82 88 74 76 76 72 C78 68 92 62 92 62 C92 62 79 62 79 58 C79 54 86 46 86 46 C86 46 74 48 72 44 C70 40 76 31 76 31 C76 31 65 35 63 31 C61 27 64 17 64 17 C64 17 55.5 24 54 21 C52.5 18 50 4 50 4 Z"/>
            </svg>
          </span>
          <span class="font-display text-cream font-semibold">Ottawa <span class="text-gold">Weekly</span></span>
        </a>
        <p class="text-cream/50 text-sm leading-relaxed">
          Because this city deserves to be celebrated.
        </p>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-8 text-sm">
        <div class="flex flex-col gap-2">
          <span class="text-cream/30 uppercase tracking-widest text-xs font-semibold">Navigate</span>
          <a href="/archive" class="text-cream/60 hover:text-cream transition-colors duration-200">Archive</a>
          <a href="/about" class="text-cream/60 hover:text-cream transition-colors duration-200">About</a>
          <a href="/#subscribe" class="text-cream/60 hover:text-cream transition-colors duration-200">Subscribe</a>
        </div>
        <div class="flex flex-col gap-2">
          <span class="text-cream/30 uppercase tracking-widest text-xs font-semibold">Legal</span>
          <a href="/privacy" class="text-cream/60 hover:text-cream transition-colors duration-200">Privacy Policy</a>
        </div>
        <div class="flex flex-col gap-2">
          <span class="text-cream/30 uppercase tracking-widest text-xs font-semibold">Follow</span>
          <a
            href="https://instagram.com/ottawaweekly"
            target="_blank"
            rel="noopener noreferrer"
            class="text-cream/60 hover:text-cream transition-colors duration-200 flex items-center gap-1.5"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            Instagram
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-cream/30 text-xs">
      © {year} Ottawa Weekly. Curated with care in Ottawa, Ontario.
    </div>
  </div>
</footer>
