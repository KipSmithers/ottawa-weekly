---
export interface Props {
  title: string;
  date_time: string;
  location: string;
  description: string;
  source_url?: string;
  variant?: 'default' | 'featured' | 'family';
}

const {
  title,
  date_time,
  location,
  description,
  source_url,
  variant = 'default',
} = Astro.props;
---

{variant === 'featured' ? (
  <div class="bg-forest rounded-card p-8 shadow-newsletter">
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="text-xs font-semibold uppercase tracking-widest text-gold bg-gold/10 border border-gold/20 px-3 py-1 rounded-full">
        Featured This Week
      </span>
    </div>
    <h3 class="font-display text-cream text-2xl md:text-3xl font-bold mb-3 leading-tight">
      {title}
    </h3>
    <div class="flex flex-wrap gap-x-4 gap-y-1 mb-4 text-sm text-cream/60">
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        {date_time}
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        {location}
      </span>
    </div>
    <p class="text-cream/75 leading-relaxed mb-6">{description}</p>
    {source_url && (
      <a
        href={source_url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-gold hover:bg-gold-hover text-forest font-semibold text-sm px-5 py-2.5 rounded-md transition-colors duration-200"
      >
        Get Tickets & Details
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    )}
  </div>
) : variant === 'family' ? (
  <div class="bg-white border-l-4 border-sage rounded-r-card p-5 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200">
    <h4 class="font-display text-forest font-semibold text-base mb-1.5 leading-snug">
      {title}
    </h4>
    <div class="flex flex-wrap gap-x-3 gap-y-0.5 mb-2 text-xs text-muted">
      <span>{date_time}</span>
      <span class="text-sage">·</span>
      <span>{location}</span>
    </div>
    <p class="text-sm text-gray-700 leading-relaxed mb-3">{description}</p>
    {source_url && (
      <a
        href={source_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-sage hover:text-sage font-semibold inline-flex items-center gap-1 group"
      >
        More info
        <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    )}
  </div>
) : (
  <div class="bg-cream-dark rounded-card p-5 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200 flex flex-col">
    <h4 class="font-display text-forest font-semibold text-base mb-1.5 leading-snug">
      {title}
    </h4>
    <div class="flex flex-wrap gap-x-3 gap-y-0.5 mb-2.5 text-xs text-muted">
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        {date_time}
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        {location}
      </span>
    </div>
    <p class="text-sm text-gray-700 leading-relaxed flex-1 mb-3">{description}</p>
    {source_url && (
      <a
        href={source_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-gold hover:text-gold-hover font-semibold inline-flex items-center gap-1 group mt-auto"
      >
        More info
        <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    )}
  </div>
)}
