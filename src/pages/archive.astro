---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allIssues = await getCollection('issues');
const sorted = allIssues.sort((a, b) =>
  new Date(b.data.publish_date).getTime() - new Date(a.data.publish_date).getTime()
);
---

<Layout
  title="Archive"
  description="Browse all past issues of Ottawa Weekly — your Thursday guide to the best of Ottawa."
>
  <Nav />

  <main>
    <!-- Header -->
    <section class="bg-forest">
      <div class="max-w-5xl mx-auto px-6 py-16">
        <p class="text-gold text-xs font-semibold uppercase tracking-widest mb-2">Ottawa Weekly</p>
        <h1 class="font-display text-cream text-4xl font-bold mb-3">The Archive</h1>
        <p class="text-cream/60 max-w-lg">
          Every issue, from the beginning. Each one a snapshot of what was worth doing in Ottawa that week.
        </p>
      </div>
    </section>

    <!-- Issues Grid -->
    <section class="max-w-5xl mx-auto px-6 py-12">
      {sorted.length === 0 ? (
        <p class="text-muted text-center py-16">No issues yet — check back Thursday.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {sorted.map((issue) => {
            const date = new Date(issue.data.publish_date);
            const formatted = date.toLocaleDateString('en-CA', {
              weekday: 'long',
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <a
                href={`/issues/${issue.id}`}
                class="bg-white rounded-card p-6 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200 group block border border-gray-100"
              >
                {issue.data.issue_number && (
                  <p class="text-xs text-gold font-semibold uppercase tracking-widest mb-2">
                    Issue #{issue.data.issue_number}
                  </p>
                )}
                <h2 class="font-display text-forest font-bold text-lg leading-snug mb-1 group-hover:text-gold transition-colors duration-200">
                  {issue.data.title}
                </h2>
                <p class="text-xs text-muted mb-3">{formatted}</p>
                <p class="text-sm text-gray-600 leading-relaxed line-clamp-3">
                  {issue.data.summary}
                </p>
                <p class="text-xs text-gold font-semibold mt-4 group-hover:text-gold-hover transition-colors duration-200">
                  Read this issue →
                </p>
              </a>
            );
          })}
        </div>
      )}
    </section>
  </main>

  <Footer />
</Layout>
