---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found"
  description="This page doesn't exist — but Ottawa does."
>
  <Nav />

  <main class="min-h-[60vh] flex items-center">
    <div class="max-w-xl mx-auto px-6 py-20 text-center">
      <p class="text-gold font-display text-8xl font-bold mb-4 opacity-30">404</p>
      <h1 class="font-display text-forest text-2xl font-bold mb-3">
        This page doesn't exist.
      </h1>
      <p class="text-gray-600 mb-8">
        But there's plenty happening in Ottawa that does. Try the homepage or browse past issues.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/"
          class="bg-gold hover:bg-gold-hover text-forest font-semibold px-5 py-2.5 rounded-md text-sm transition-colors duration-200"
        >
          Go home
        </a>
        <a
          href="/archive"
          class="border border-gray-300 hover:border-gold text-gray-700 hover:text-gold font-medium px-5 py-2.5 rounded-md text-sm transition-colors duration-200"
        >
          Browse the archive
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
