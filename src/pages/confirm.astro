---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="You're In"
  description="Welcome to Ottawa Weekly. See you Thursday."
  noindex={true}
>
  <Nav />

  <main class="min-h-[60vh] flex items-center">
    <div class="max-w-xl mx-auto px-6 py-20 text-center">
      <div class="text-gold mb-6 flex justify-center">
        <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h1 class="font-display text-forest text-3xl font-bold mb-4">
        You're in. See you Thursday.
      </h1>
      <p class="text-gray-600 text-lg leading-relaxed mb-8">
        Welcome to Ottawa Weekly. Every Thursday morning you'll get our curated guide to the best the city has to offer that weekend.
      </p>
      <a
        href="/archive"
        class="bg-gold hover:bg-gold-hover text-forest font-semibold px-6 py-3 rounded-md text-sm transition-colors duration-200 inline-block"
      >
        Browse past issues while you wait →
      </a>
    </div>
  </main>

  <Footer />
</Layout>
