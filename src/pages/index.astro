---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';

const allIssues = await getCollection('issues');
const sorted = allIssues.sort((a, b) =>
  new Date(b.data.publish_date).getTime() - new Date(a.data.publish_date).getTime()
);
const latest = sorted[0];
const recentIssues = sorted.slice(0, 4);
---

<Layout
  title="Ottawa Weekly"
  description="Your guide to the best of Ottawa, every Thursday. Curated events, food, arts, and outdoor adventures — only the good stuff."
>
  <Nav />

  <!-- Hero -->
  <section class="bg-forest relative overflow-hidden">
    <!-- Background radial glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-gold/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-20 md:py-28 relative">
      <div class="max-w-2xl">
        <!-- Eyebrow -->
        <div class="flex items-center gap-2 mb-6">
          <span class="text-gold w-5 h-5 flex-shrink-0">
            <svg viewBox="0 0 100 112" fill="currentColor" aria-hidden="true" class="w-full h-full">
              <path d="M50 4 C50 4 47.5 18 46 21 C44.5 24 36 17 36 17 C36 17 39 27 37 31 C35 35 24 31 24 31 C24 31 30 40 28 44 C26 48 14 46 14 46 C14 46 21 54 21 58 C21 62 8 62 8 62 C8 62 22 68 24 72 C26 76 18 88 18 88 C18 88 32 83 40 86 L40 96 L44 108 L56 108 L60 96 L60 86 C68 83 82 88 82 88 C82 88 74 76 76 72 C78 68 92 62 92 62 C92 62 79 62 79 58 C79 54 86 46 86 46 C86 46 74 48 72 44 C70 40 76 31 76 31 C76 31 65 35 63 31 C61 27 64 17 64 17 C64 17 55.5 24 54 21 C52.5 18 50 4 50 4 Z"/>
            </svg>
          </span>
          <span class="text-gold text-sm font-semibold uppercase tracking-widest">Ottawa Weekly</span>
        </div>

        <h1 class="font-display text-cream text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-5">
          Your guide to the<br />
          best of <span class="text-gold">Ottawa</span>,<br />
          every Thursday.
        </h1>

        <p class="text-cream/70 text-lg leading-relaxed mb-8 max-w-lg">
          A weekly digest of the city's best events, food finds, and outdoor adventures — curated by someone who actually lives here. No politics, no crime, just Ottawa at its best.
        </p>

        <!-- Subscribe Form -->
        <div id="subscribe" class="mb-6">
          <SubscribeForm
            variant="hero"
            subtext="Join 1,200+ Ottawa readers getting this every Thursday."
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Value Strip -->
  <section class="bg-forest-mid border-t border-b border-white/10">
    <div class="max-w-5xl mx-auto px-6 py-10 grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>`,
          label: 'Curated every week',
          desc: 'Not an algorithm. A real person picks what goes in — things worth your time.',
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
          label: 'Only the good stuff',
          desc: 'Arts, food, outdoors, and community. No crime, no politics, no negativity.',
        },
        {
          icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
          label: 'Every Thursday, free',
          desc: 'Lands in your inbox every Thursday morning. Always free, unsubscribe anytime.',
        },
      ].map(item => (
        <div class="flex items-start gap-4">
          <span class="text-gold mt-0.5 flex-shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={item.icon} />
          </span>
          <div>
            <p class="text-cream font-semibold text-sm mb-1">{item.label}</p>
            <p class="text-cream/50 text-sm leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Latest Issue Preview -->
  {latest && (
    <section class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8">
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-widest mb-1">Latest Issue</p>
          <h2 class="font-display text-forest text-2xl md:text-3xl font-bold">{latest.data.title}</h2>
          <p class="text-muted text-sm mt-1">
            {new Date(latest.data.publish_date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
            {latest.data.issue_number && ` · Issue #${latest.data.issue_number}`}
          </p>
        </div>
        <a
          href={`/issues/${latest.id}`}
          class="text-sm text-gold font-semibold hover:text-gold-hover transition-colors duration-200 flex-shrink-0"
        >
          Read full issue →
        </a>
      </div>

      {latest.data.editor_note && (
        <div class="bg-cream-dark border border-cream-dark rounded-card p-6 mb-8 italic text-gray-700 leading-relaxed border-l-4 border-l-gold">
          <p class="text-sm font-semibold text-gold not-italic mb-1 uppercase tracking-widest text-xs">Editor's Note</p>
          "{latest.data.editor_note}"
        </div>
      )}

      <!-- Featured Event -->
      <div class="mb-8">
        <EventCard {...latest.data.featured_event} variant="featured" />
      </div>

      <!-- Highlights (show first 2) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        {latest.data.highlights.slice(0, 2).map(event => (
          <EventCard {...event} />
        ))}
      </div>

      <!-- CTA -->
      <div class="bg-forest rounded-card p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="font-display text-cream font-semibold">There's more in this issue.</p>
          <p class="text-cream/60 text-sm">Subscribe to get the full edition every Thursday.</p>
        </div>
        <div class="flex gap-3 flex-shrink-0">
          <a href={`/issues/${latest.id}`} class="text-cream/70 hover:text-cream text-sm font-medium transition-colors duration-200 flex items-center">
            Read full issue
          </a>
          <a href="#subscribe" class="bg-gold hover:bg-gold-hover text-forest font-semibold text-sm px-5 py-2.5 rounded-md transition-colors duration-200">
            Subscribe
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Archive Teaser -->
  <section class="bg-cream-dark border-t border-gray-200">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8">
        <div>
          <p class="text-gold text-xs font-semibold uppercase tracking-widest mb-1">Past Issues</p>
          <h2 class="font-display text-forest text-2xl font-bold">From the Archive</h2>
        </div>
        <a href="/archive" class="text-sm text-gold font-semibold hover:text-gold-hover transition-colors duration-200 flex-shrink-0">
          Browse all issues →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {recentIssues.map(issue => (
          <a
            href={`/issues/${issue.id}`}
            class="bg-white rounded-card p-5 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all duration-200 group block"
          >
            <p class="text-xs text-muted mb-1">
              {new Date(issue.data.publish_date).toLocaleDateString('en-CA', { month: 'short', day: 'numeric', year: 'numeric' })}
            </p>
            <p class="font-display text-forest font-semibold text-sm group-hover:text-gold transition-colors duration-200 leading-snug mb-2">
              {issue.data.title}
            </p>
            <p class="text-xs text-muted leading-relaxed line-clamp-2">{issue.data.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer Subscribe CTA -->
  <section class="bg-forest">
    <div class="max-w-5xl mx-auto px-6 py-16 text-center">
      <p class="font-display text-cream text-3xl font-bold mb-2">
        Don't miss next Thursday's edition.
      </p>
      <p class="text-cream/60 mb-8">Join Ottawa readers who start their weekend planning early.</p>
      <div class="max-w-md mx-auto">
        <SubscribeForm variant="footer" />
      </div>
    </div>
  </section>

  <Footer />
</Layout>
