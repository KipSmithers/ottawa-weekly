---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Check Your Inbox"
  description="Thanks for subscribing to Ottawa Weekly. Check your inbox to confirm."
  noindex={true}
>
  <Nav />

  <main class="min-h-[60vh] flex items-center">
    <div class="max-w-xl mx-auto px-6 py-20 text-center">
      <div class="text-gold mb-6 flex justify-center">
        <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <h1 class="font-display text-forest text-3xl font-bold mb-4">
        Check your inbox.
      </h1>
      <p class="text-gray-600 text-lg leading-relaxed mb-6">
        We sent you a confirmation email. Click the link inside to complete your subscription and start getting Ottawa Weekly every Thursday.
      </p>
      <p class="text-muted text-sm mb-8">
        Don't see it? Check your spam folder — then add <strong>hello@ottawaweekly.ca</strong> to your contacts so future issues land right.
      </p>
      <a
        href="/archive"
        class="inline-flex items-center gap-2 text-sm text-gold font-semibold hover:text-gold-hover transition-colors duration-200"
      >
        While you wait, browse past issues →
      </a>
    </div>
  </main>

  <Footer />
</Layout>
